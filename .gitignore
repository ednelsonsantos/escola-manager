# ── Dependências ──────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Build outputs ─────────────────────────────────────────────────────────────
dist/
dist-electron/
release/
out/

# ── Electron Builder ──────────────────────────────────────────────────────────
# Instaladores e pacotes gerados pelo electron-builder
*.exe
*.msi
*.dmg
*.AppImage
*.snap
*.deb
*.rpm
*.zip
*.tar.gz

# ── Banco de dados local (gerado em runtime) ──────────────────────────────────
# O arquivo escola.db fica em %APPDATA%/Escola Manager/ no Windows
# A pasta db/ local é apenas para desenvolvimento
db/*.db
db/*.db-wal
db/*.db-shm
*.db
*.db-wal
*.db-shm

# ── Variáveis de ambiente / secrets ───────────────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ── Logs ──────────────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# ── Cache e temporários ───────────────────────────────────────────────────────
.cache/
.vite/
.temp/
tmp/
temp/

# ── IDEs e editores ───────────────────────────────────────────────────────────
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Sistema operacional ───────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Cobertura de testes ───────────────────────────────────────────────────────
coverage/
*.lcov

# ── TypeScript ────────────────────────────────────────────────────────────────
*.tsbuildinfo

# ── Electron — arquivos gerados no desenvolvimento ───────────────────────────
# Necessário para reconstrução dos módulos nativos (better-sqlite3)
# Esses ficam dentro de node_modules (já ignorado acima) e não no repo
