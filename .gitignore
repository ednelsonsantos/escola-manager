# ── Dependências ──────────────────────────────────────────────────────────────
node_modules/
.npm/

# ── Build / Dist ──────────────────────────────────────────────────────────────
dist/
dist-electron/
out/
release/
build/

# ── Electron Builder ──────────────────────────────────────────────────────────
# Instaladores e artefatos de build — gerados pelo CI/CD ou npm run build
*.exe
*.dmg
*.AppImage
*.deb
*.rpm
*.snap
*.msi
*.nsis
win-unpacked/
linux-unpacked/
mac/

# ── Banco de Dados ────────────────────────────────────────────────────────────
# SQLite gerado em runtime — não versionar dados de produção
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# ── Cache e ambiente ──────────────────────────────────────────────────────────
.vite/
.cache/
.parcel-cache/
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ── Editores / IDEs ───────────────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store
Thumbs.db
desktop.ini

# ── Backups gerados pelo sistema ──────────────────────────────────────────────
# (ficam em %APPDATA% em produção — não commitar)
backups/

# ── Arquivos temporários ──────────────────────────────────────────────────────
*.tmp
*.temp
*.bak
*.orig
